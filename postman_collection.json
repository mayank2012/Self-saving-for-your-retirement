            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"expenses\": [{\"date\": \"2024-01-15T10:30:00Z\", \"amount\": 250}, {\"date\": \"2024-01-15T10:30:00Z\", \"amount\": 100}], \"q_periods\": [], \"p_periods\": [], \"k_periods\": []}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/validate",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "validate"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 422 (Unprocessable Entity)', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('Validation fails due to duplicates', function () {",
                  "    let jsonData = pm.response.json();",
                  "    pm.expect(jsonData.valid).to.be.false;",
                  "    pm.expect(jsonData.duplicates_detected.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
